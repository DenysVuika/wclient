{
  "name": "wclient-workspace",
  "packageManager": "pnpm@11.13.1",
  "version": "0.1.0",
  "description": "Workspace for the wclient library and related apps.",
  "author": "Denys Vuika <denys.vuika@gmail.com>",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter ./packages/* --filter ./apps/* build",
    "typecheck": "pnpm -r --filter ./packages/* --filter ./apps/* typecheck",
    "test": "pnpm -r --filter ./packages/* --filter ./apps/* test",
    "test:watch": "pnpm -r --parallel --filter ./packages/* --filter ./apps/* test:watch",
    "lint": "pnpm -r --filter ./packages/* --filter ./apps/* lint",
    "lint:fix": "pnpm -r --filter ./packages/* --filter ./apps/* lint:fix",
    "format": "pnpm -r --filter ./packages/* --filter ./apps/* format",
    "format:check": "pnpm -r --filter ./packages/* --filter ./apps/* format:check",
    "start": "pnpm --filter @wclient/playground start",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm --filter wclient build && changeset publish"
  },
  "keywords": [],
  "license": "Apache-2.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.25.0",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
